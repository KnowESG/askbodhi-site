# AskBodhi Environment Variables
# Copy to .env.local and fill in values

# Analytics (future)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Contact form endpoint (future)
# CONTACT_FORM_API_KEY=
# CONTACT_FORM_ENDPOINT=

# Domain (used in sitemap/robots if dynamic)
# NEXT_PUBLIC_SITE_URL=https://askbodhi.com
