# AskBodhi Environment Variables
# Copy to .env.local and fill in values

# Domain
# NEXT_PUBLIC_SITE_URL=https://askbodhi.ai

# Analytics (future)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email service for form submissions (future — currently logs to Vercel function logs)
# RESEND_API_KEY=re_xxxxxxxxxx
# CONTACT_EMAIL_TO=info@askbodhi.ai
